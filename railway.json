{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci --include-workspace-root && npm run build --workspace=apps/shared && npm run build --workspace=apps/backend",
    "startCommand": "node apps/backend/dist/src/main.js"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120
  }
}
